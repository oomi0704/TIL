{
	"nodes": [
		{
			"id": "title",
			"type": "text",
			"text": "# AWS SAA メモリツリー\n\n**使い方**: 矢印を辿ってサービスを決める\n\n詳細: [[メモリツリー-AWS-SAA]]",
			"x": -200,
			"y": -400,
			"width": 400,
			"height": 180,
			"color": "6"
		},
		{
			"id": "g1",
			"type": "group",
			"label": "§1 接続",
			"x": -1400,
			"y": -200,
			"width": 520,
			"height": 520,
			"color": "5"
		},
		{
			"id": "c1q",
			"type": "text",
			"text": "**誰と誰？**",
			"x": -1360,
			"y": -160,
			"width": 120,
			"height": 60
		},
		{
			"id": "c1a",
			"type": "text",
			"text": "オンプレ↔AWS\n・早い安い → **VPN**\n・専用線 → **DX**",
			"x": -1360,
			"y": -60,
			"width": 200,
			"height": 120,
			"color": "4"
		},
		{
			"id": "c1b",
			"type": "text",
			"text": "VPC↔VPC\n・2つ → **Peering**\n・多数 → **TGW**",
			"x": -1120,
			"y": -60,
			"width": 200,
			"height": 120,
			"color": "4"
		},
		{
			"id": "c1c",
			"type": "text",
			"text": "VPC↔S3等\n・無料 → **GW Endpoint**\n・他 → **IF Endpoint**",
			"x": -1360,
			"y": 100,
			"width": 220,
			"height": 120,
			"color": "4"
		},
		{
			"id": "c1d",
			"type": "text",
			"text": "IP拒否 → **NACL**\nインスタンス → **SG**",
			"x": -1100,
			"y": 100,
			"width": 180,
			"height": 100,
			"color": "3"
		},
		{
			"id": "g2",
			"type": "group",
			"label": "§2 ストレージ・S3",
			"x": -700,
			"y": -200,
			"width": 520,
			"height": 560,
			"color": "2"
		},
		{
			"id": "s2q",
			"type": "text",
			"text": "**S3クラス**",
			"x": -660,
			"y": -160,
			"width": 120,
			"height": 50
		},
		{
			"id": "s2a",
			"type": "text",
			"text": "パターン不明\n→ **Intelligent-Tiering**",
			"x": -660,
			"y": -80,
			"width": 200,
			"height": 90,
			"color": "4"
		},
		{
			"id": "s2b",
			"type": "text",
			"text": "月1回・即時\n→ **Standard-IA**",
			"x": -420,
			"y": -80,
			"width": 180,
			"height": 90,
			"color": "4"
		},
		{
			"id": "s2c",
			"type": "text",
			"text": "年1回・即時\n→ **Glacier Instant**",
			"x": -660,
			"y": 40,
			"width": 200,
			"height": 90,
			"color": "4"
		},
		{
			"id": "s2d",
			"type": "text",
			"text": "最安・ほぼ読まない\n→ **Deep Archive**",
			"x": -420,
			"y": 40,
			"width": 200,
			"height": 90,
			"color": "4"
		},
		{
			"id": "s2e",
			"type": "text",
			"text": "EBS: 汎用 **gp3**\n高IOPS **io2**\nオブジェクト **S3**",
			"x": -660,
			"y": 160,
			"width": 440,
			"height": 100,
			"color": "3"
		},
		{
			"id": "g3",
			"type": "group",
			"label": "§3 データベース",
			"x": 0,
			"y": -200,
			"width": 480,
			"height": 480,
			"color": "1"
		},
		{
			"id": "d3q",
			"type": "text",
			"text": "**SQL?**",
