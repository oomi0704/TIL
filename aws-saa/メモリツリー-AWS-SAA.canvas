			"y": -160,
			"width": 100,
			"height": 50
		},
		{
			"id": "d3a",
			"type": "text",
			"text": "YES\n安い → RDS\n速い → **Aurora**",
			"x": 40,
			"y": -80,
			"width": 160,
			"height": 100,
			"color": "4"
		},
		{
			"id": "d3b",
			"type": "text",
			"text": "NO\n→ **DynamoDB** 等",
